{
  "expo": {
    "name": "Mensagem Transformadora",
    "slug": "mensagem-transformadora",
    "version": "1.0.8",
    "icon": "./img/icon.png",
    "orientation": "default",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.algoritmum.msgt",
      "versionCode": 8,
      "edgeToEdge": true,
      "adaptiveIcon": {
        "foregroundImage": "./img/adaptive-icon.png",
        "backgroundColor": "#071A3A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "www.mensagemtransformadora.com.br",
              "pathPrefix": "/"
            }
          ]
        }
      ]
    },
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./img/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#071A3A"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "8d2903af-1918-4196-9a01-90898f46807e"
      }
    },
    "ios": {
      "bundleIdentifier": "n"
    }
  }
}
